{
	"compilerOptions": {
		"target": "ES2015",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"outDir": "dist",
		"sourceMap": true,
		"declaration": true,
		"declarationDir": "dist/types",
		"esModuleInterop": true,
		"skipLibCheck": true
	},
	"include": ["src/**/*.ts"]
}
